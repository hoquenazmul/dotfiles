set relativenumber
set scrolloff=5
set clipboard=unnamedplus

let mapleader=" "

" --- General ---
nnoremap <leader>ff :action GotoFile<CR>
nnoremap <leader>fg :action FindInPath<CR>
nnoremap <leader>fr :action RecentFiles<CR>
nnoremap <leader>rn :action RenameElement<CR>
nnoremap <leader>ca :action ShowIntentionActions<CR> " quick fix
nnoremap <leader>cf :action ReformatCode<CR>
nnoremap <leader>e  :action ActivateProjectToolWindow<CR>

" --- Debugging ---
nnoremap <leader>r  :action Run<CR>
nnoremap <leader>d  :action Debug<CR>
nnoremap <leader>so :action StepOver<CR>
nnoremap <leader>si :action StepInto<CR>
nnoremap <leader>su :action StepOut<CR>
nnoremap <leader>q  :action Stop<CR>
nnoremap <leader>tb :action ToggleLineBreakpoint<CR>
nnoremap <leader>c  :action Resume<CR>
nnoremap <leader>dc :action DebugConsole<CR>